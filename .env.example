# ═══════════════════════════════════════
# Agent Lead — Backend Configuration
# ═══════════════════════════════════════
# Copy this file to backend/.env:
#   cp .env.example backend/.env

# ── Server ──────────────────────────
PORT=3002
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# ── URLs ────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3002

# ── Supabase (REQUIRED) ────────────
# Get from: supabase.com/dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Encryption (REQUIRED) ──────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# ── JWT Secret ──────────────────────
JWT_SECRET=your-jwt-secret-here

# ── Premium Scraping (SerpAPI) ──────
# Get from: https://serpapi.com — enables the "Premium" scraper
SERPAPI_KEY=your-serpapi-key-here

# ── Google Maps API (optional) ──────
# Enables direct Google Places scraping (free tier fallback works without this)
# GOOGLE_PLACES_API_KEY=your-key-here

# ── Meta (Facebook/Instagram) OAuth ─
# Required for Instagram DMs + Facebook Messenger
# Get from: developers.facebook.com → Your App
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret

# ── Google OAuth (Gmail sending) ────
# Required for Google/Gmail email OAuth flow
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email Service (optional) ────────
# Choose sendgrid or nodemailer
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your-key-here
# EMAIL_FROM=noreply@yourdomain.com

# ── SMS/WhatsApp via Twilio (optional)
# TWILIO_ACCOUNT_SID=your-sid-here
# TWILIO_AUTH_TOKEN=your-token-here
# TWILIO_PHONE_NUMBER=+1234567890

# ═══════════════════════════════════════
# Supabase Secrets (set via CLI, not .env)
# ═══════════════════════════════════════
# These are set as Supabase secrets, not in this file:
#   supabase secrets set ANTHROPIC_API_KEY=your-key    (AI lead qualification)
#   supabase secrets set GEMINI_API_KEY=your-key       (AI message personalization)
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_... (Stripe payments)
#   supabase secrets set RESEND_API_KEY=re_...         (Email via Resend)

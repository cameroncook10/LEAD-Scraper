# Backend Configuration
PORT=3002
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API (for Claude Haiku)
ANTHROPIC_API_KEY=your-api-key-here

# Encryption (AES-256-GCM) - REQUIRED for field-level encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# JWT Secret
JWT_SECRET=your-jwt-secret-here

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:19006,exp://localhost:8081

# Frontend URL (for webhooks, tracking pixels, unsubscribe links)
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3002

# Optional: Third-party scraper APIs
# GOOGLE_MAPS_API_KEY=your-key-here
# SERPAPI_KEY=your-key-here
# BRIGHT_DATA_API_KEY=your-key-here

# Optional: Email Service (sendgrid or nodemailer)
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your-key-here
# EMAIL_FROM=noreply@yourdomain.com

# Optional: SMS/WhatsApp (Twilio)
# TWILIO_ACCOUNT_SID=your-sid-here
# TWILIO_AUTH_TOKEN=your-token-here
# TWILIO_PHONE_NUMBER=+1234567890

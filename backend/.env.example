# ═══════════════════════════════════════
# Agent Lead — Environment Configuration
# ═══════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Supabase ──────────────────────────
# Get these from: supabase.com/dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ───────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
# Get from: dashboard.stripe.com → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Encryption ────────────────────────
# 32+ character random string for AES-256-GCM field encryption
ENCRYPTION_KEY=change-me-to-a-32-char-random-string

# ── DM Providers ──────────────────────
# Instagram Graph API (requires Meta Business account)
# Get from: developers.facebook.com → Your App → Generate Token
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Facebook Messenger API
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── AI Personalization ────────────────
# OpenAI API key for message personalization
OPENAI_API_KEY=sk-...

# ── Server ────────────────────────────
PORT=3002
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:5173

# Trading Bot Configuration

# ============== REQUIRED API KEYS ==============

# Anthropic API Key (for Claude/Opus decision-making)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# X/Twitter API Key (optional, for sentiment analysis)
XAI_API_KEY=xai_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============== TRADING PARAMETERS ==============

# Minimum confidence threshold for trade execution (0-100)
MIN_CONFIDENCE=60

# Maximum position size as % of portfolio (0-100)
MAX_POSITION_SIZE=25

# Maximum risk per trade as % of total portfolio (0-100)
MAX_PORTFOLIO_RISK=10

# Minimum market health score to trade (0-100)
MIN_MARKET_HEALTH=50

# Starting capital for paper trading ($)
START_CAPITAL=10000

# ============== RISK MANAGEMENT ==============

# Default stop loss as % below entry price
DEFAULT_STOP_LOSS=5

# Default take profit as % above entry price
DEFAULT_TAKE_PROFIT=15

# Maximum daily drawdown allowed (%)
MAX_DRAWDOWN=20

# ============== TRADING MODE ==============

# Paper trading mode (true = simulated, false = live)
PAPER_TRADING=true

# Auto-execute trades (false = manual approval required)
AUTO_EXECUTE=false

# Require human approval for trades above confidence threshold
REQUIRE_APPROVAL=true

# Symbols to trade (comma-separated)
WATCHLIST=BTC,ETH,SOL,ADA,DOGE

# ============== SCHEDULING ==============

# Cron schedule for market analysis (default: every hour)
ANALYSIS_CRON=0 * * * *

# Cron schedule for improvement agent (default: every 2 hours)
IMPROVEMENT_CRON=0 */2 * * *

# Cron schedule for backtesting (default: weekly Sunday)
BACKTEST_CRON=0 0 * * 0

# ============== LOGGING ==============

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Directory for log files
LOGS_DIR=./logs

# ============== FEATURES ==============

# Enable sentiment analysis
SENTIMENT_ENABLED=true

# Enable technical analysis
TECHNICAL_ANALYSIS_ENABLED=true

# Enable on-chain analysis (requires additional APIs)
ONCHAIN_ANALYSIS_ENABLED=false

# Enable improvement agent
IMPROVEMENT_AGENT_ENABLED=true

# Enable backtesting
BACKTESTING_ENABLED=true

# ============== NOTIFICATIONS ==============

# Enable notifications
NOTIFICATIONS_ENABLED=false

# Enable email notifications
EMAIL_ENABLED=false

# Enable Discord webhooks
DISCORD_ENABLED=false

# Enable Telegram notifications
TELEGRAM_ENABLED=false

# ============== DATABASE (Optional) ==============

# Enable database persistence
DATABASE_ENABLED=false

# Database type (supabase, postgresql, etc.)
DATABASE_TYPE=supabase

# Database connection URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============== DATA SOURCES ==============

# Price data source (coingecko, binance, kraken)
# Note: coingecko is free and no API key required
PRICE_DATA_SOURCE=coingecko

# Market research source (web_search, news_api)
MARKET_RESEARCH_SOURCE=web_search

# Sentiment source (twitter_search, news_sentiment)
SENTIMENT_SOURCE=twitter_search

# On-chain data source (glassnode, nansen)
ONCHAIN_DATA_SOURCE=glassnode

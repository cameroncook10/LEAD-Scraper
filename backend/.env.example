# ═══════════════════════════════════════
# Agent Lead — Backend Environment
# ═══════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Supabase (REQUIRED) ────────────
# Get from: supabase.com/dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Encryption (REQUIRED) ──────────
# 64-char hex string for AES-256-GCM field encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string

# ── Server ──────────────────────────
PORT=3002
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3002

# ── Premium Scraping (SerpAPI) ──────
# Enables reliable, structured scraping via SerpAPI
# Get key at: https://serpapi.com
SERPAPI_KEY=

# ── Google Maps API (optional) ──────
# Direct Google Places API (free fallback works without this)
# GOOGLE_PLACES_API_KEY=

# ── Meta OAuth (Facebook/Instagram DMs) ──
# Get from: developers.facebook.com → Your App
# META_APP_ID=
# META_APP_SECRET=

# ── Google OAuth (Gmail sending) ────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Email (optional — user can configure in dashboard) ──
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com

# ── SMS/WhatsApp via Twilio (optional) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ═══════════════════════════════════════
# API keys below are stored as Supabase secrets:
#   supabase secrets set ANTHROPIC_API_KEY=...
#   supabase secrets set GEMINI_API_KEY=...
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set RESEND_API_KEY=re_...

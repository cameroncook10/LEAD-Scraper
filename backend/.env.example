# ============================================================
# AgentLead Backend — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development            # development | production
SERVICE_NAME=lead-scraper-api   # Shown in structured logs
LOG_LEVEL=info                  # info | debug

# ── Supabase ──────────────────────────────────────────────────
# Get from: supabase.com/dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key — server-side ONLY

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
FRONTEND_URL=http://localhost:3001

# ── Encryption (AES-256-GCM) ──────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── Anthropic AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email ─────────────────────────────────────────────────────
EMAIL_SERVICE=sendgrid          # sendgrid | smtp
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=AgentLead
# (SMTP fallback)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── SMS / WhatsApp (Twilio) ───────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...         # sk_live_... in production
STRIPE_PUBLISHABLE_KEY=pk_test_...    # pk_live_... in production
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Social OAuth ──────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Redis (optional) ──────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379

# ── Error Tracking (Sentry) ───────────────────────────────────
# Leave blank to disable
SENTRY_DSN=

# ── Optional 3rd-party APIs ───────────────────────────────────
GOOGLE_MAPS_API_KEY=
SERPAPI_KEY=
BRIGHT_DATA_API_KEY=

# ── Vercel (set automatically) ────────────────────────────────
# VERCEL=1

{
  "name": "agentlead-desktop",
  "version": "1.0.0",
  "description": "AgentLead — AI-powered lead generation desktop app",
  "main": "main.js",
  "author": "AgentLead",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3005 && electron .\"",
    "dev:renderer": "cd renderer && npx vite --port 3005",
    "build:renderer": "cd renderer && npx vite build",
    "build:win": "npm run build:renderer && electron-builder --win --publish always",
    "build:mac": "npm run build:renderer && electron-builder --mac --publish always",
    "build:all": "npm run build:renderer && electron-builder --win --mac --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "io.agentlead.desktop",
    "productName": "AgentLead",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!node_modules", "!.env"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "../frontend/public/logo.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "../frontend/public/logo.png",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "cameroncook10",
      "repo": "LEAD-Scraper"
    }
  }
}

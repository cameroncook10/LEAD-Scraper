# ============================================================
# AgentLead Frontend — Build-time Environment Variables
# Copy to .env.local for development.
# In production these are injected as Docker build args or
# Vercel environment variables.
# ============================================================

# API base URL (no trailing slash)
VITE_API_URL=http://localhost:3002

# Supabase — public (anon) key only; never use service_role here
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Stripe publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App version (injected by CI)
VITE_APP_VERSION=local

# Sentry (optional — leave blank to disable)
VITE_SENTRY_DSN=

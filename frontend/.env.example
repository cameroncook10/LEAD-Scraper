# ═══════════════════════════════════════
# Agent Lead — Frontend Environment
# ═══════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Supabase (required for auth + edge functions) ──
# Get these from: supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend API URL ──
# In development, the Vite proxy handles this automatically.
# In production (Vercel), set this to your backend URL.
# VITE_API_URL=https://your-backend.vercel.app/api
